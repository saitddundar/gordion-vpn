# Gordion VPN - Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit the .env file to git

# Database
DATABASE_URL=postgresql://gordion:YOUR_PASSWORD@localhost:5432/gordion?sslmode=disable
POSTGRES_PASSWORD=YOUR_PASSWORD

# JWT
JWT_SECRET=YOUR_SECRET_KEY_HERE_MIN_32_CHARS

# Grafana
GF_SECURITY_ADMIN_PASSWORD=YOUR_GRAFANA_PASSWORD

# Service Addresses
IDENTITY_ADDR=localhost:8001
DISCOVERY_ADDR=localhost:8002
CONFIG_ADDR=localhost:8003

# TLS (optional)
TLS_CERT=certs/server-cert.pem
TLS_KEY=certs/server-key.pem

# Logging
LOG_LEVEL=debug
